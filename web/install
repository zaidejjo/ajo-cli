#!/usr/bin/env bash

# ajo-cli installation script
# Optimized for speed, reliability, and security.

set -euo pipefail

# Exit codes
EXIT_SUCCESS=0
EXIT_GENERAL=1
EXIT_DEPENDENCY_MISSING=2
EXIT_PERMISSION_DENIED=3
EXIT_NETWORK_ERROR=4

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Flags
DRY_RUN=false
TEST_MODE=false
USER_INSTALL=true

# Function to print messages
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Function to handle cleanup on exit
cleanup() {
    local exit_code=$?
    if [ $exit_code -ne 0 ] && [ $exit_code -ne $EXIT_SUCCESS ]; then
        log_error "Installation failed with exit code $exit_code."
    fi
    exit $exit_code
}
trap cleanup EXIT

# Function to handle Ctrl+C
trap 'log_error "\nInstallation interrupted by user."; exit 1' INT TERM

# Function to show help
show_help() {
    echo "Usage: install.sh [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --user          Install for the current user (default)"
    echo "  --global        Install globally (requires sudo/root)"
    echo "  --test          Run in test mode (simulation)"
    echo "  --dry-run       Preview actions without making changes"
    echo "  --help          Show this help message"
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --user) USER_INSTALL=true; shift ;;
        --global) USER_INSTALL=false; shift ;;
        --test) TEST_MODE=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --help) show_help; exit 0 ;;
        *) log_error "Unknown option: $1"; show_help; exit $EXIT_GENERAL ;;
    esac
done

# Check if running via pipe
if [[ ! -t 0 ]]; then
    log_info "Running in pipe mode (curl | sh)..."
fi

# Check for dependencies
check_dependencies() {
    log_info "Checking dependencies..."
    if ! command -v python3 &> /dev/null; then
        log_error "Python 3 is required but not found. Please install Python 3.8+."
        exit $EXIT_DEPENDENCY_MISSING
    fi
    if ! command -v pip3 &> /dev/null && ! command -v pip &> /dev/null; then
        log_error "pip is required but not found. Please install pip."
        exit $EXIT_DEPENDENCY_MISSING
    fi
    if ! command -v git &> /dev/null; then
        log_warn "git is not installed. It will be required if we fallback to source installation."
    fi
}

# Detect OS
detect_os() {
    case "$(uname -s)" in
        Linux*)     OS="Linux";;
        Darwin*)    OS="macOS";;
        CYGNW*)     OS="Windows";;
        *)          OS="Unknown";;
    esac
    log_info "Detected OS: $OS"
    if [ "$OS" = "Unknown" ]; then
        log_error "Unsupported operating system."
        exit $EXIT_GENERAL
    fi
}

# Function to install uv
install_uv() {
    log_info "Installing uv..."
    if ! curl -LsSf https://astral.sh/uv/install.sh | sh; then
        log_error "Failed to install uv."
        return 1
    fi
    
    # Add uv to current session PATH
    export PATH="$HOME/.cargo/bin:$HOME/.local/bin:$PATH"
    
    if command -v uv &> /dev/null; then
        log_success "uv installed successfully!"
        return 0
    else
        log_error "uv installed but not found in PATH."
        return 1
    fi
}

# Perform installation
install_ajo() {
    log_info "Starting installation of ajo-cli..."
    
    if [ "$DRY_RUN" = true ]; then
        log_info "[DRY-RUN] Would attempt installation via uv (with optional install), then pipx, then source."
        return 0
    fi

    if [ "$TEST_MODE" = true ]; then
        log_info "[TEST-MODE] Simulating installation..."
        sleep 1
        log_success "Simulated installation complete."
        return 0
    fi

    # 1. Try uv
    if ! command -v uv &> /dev/null; then
        # Only prompt if the session is interactive
        if [[ -t 0 ]]; then
            read -p "uv is not installed. Would you like to install it first? [Y/n]: " response
            response=${response:-Y} # Default to Y
            if [[ "$response" =~ ^([Yy])$ ]]; then
                if ! install_uv; then
                    log_warn "uv installation failed. Moving to next fallback..."
                fi
            else
                log_info "Skipping uv installation."
            fi
        else
            log_info "Non-interactive session. Skipping uv prompt."
        fi
    fi

    if command -v uv &> /dev/null; then
        log_info "Using 'uv' to install ajo-cli..."
        if ! uv tool install ajo-cli; then
            log_error "Failed to install via uv."
            exit $EXIT_GENERAL
        fi
        log_success "ajo-cli installed successfully via uv!"
        return 0
    fi

    # 2. Try pipx
    if command -v pipx &> /dev/null; then
        log_info "Found 'pipx'. Installing via pipx..."
        if ! pipx install ajo-cli; then
            log_error "Failed to install via pipx."
            exit $EXIT_GENERAL
        fi
        log_success "ajo-cli installed successfully via pipx!"
        return 0
    fi

    # 3. Fallback to source
    log_warn "Neither 'uv' nor 'pipx' found. Falling back to source installation..."
    
    if ! command -v git &> /dev/null; then
        log_error "git is required for source installation but not found."
        exit $EXIT_DEPENDENCY_MISSING
    fi

    local repo_dir="ajo-cli-temp"
    [ -d "$repo_dir" ] && rm -rf "$repo_dir"

    log_info "Cloning repository to $repo_dir..."
    if ! git clone --depth 1 https://github.com/zaidejjo/ajo-cli.git "$repo_dir"; then
        log_error "Failed to clone repository."
        exit $EXIT_NETWORK_ERROR
    fi

    cd "$repo_dir"
    
    local pip_cmd="pip3"
    if ! command -v pip3 &> /dev/null && command -v pip &> /dev/null; then
        pip_cmd="pip"
    fi

    local install_cmd="$pip_cmd install ."
    if [ "$USER_INSTALL" = false ]; then
        install_cmd="sudo $pip_cmd install ."
    fi

    log_info "Installing from source using $install_cmd..."
    if ! eval "$install_cmd"; then
        log_error "Failed to install from source."
        cd ..
        rm -rf "$repo_dir"
        exit $EXIT_GENERAL
    fi
    cd ..

    log_info "Cleaning up source code..."
    rm -rf "$repo_dir"

    log_success "ajo-cli installed successfully from source!"
}

# Main execution
main() {
    check_dependencies
    detect_os
    install_ajo
    
    log_success "ajo-cli installed successfully!"
    log_info "Verify installation by running: ajo --version"
}

main
