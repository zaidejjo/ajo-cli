  <!-- JavaScript Polish -->
  <script>
    // Initialize Lucide Icons
    lucide.createIcons();

    // Theme Switcher Logic
    const themes = ['cyberpunk', 'dracula', 'monochromatic'];
    let currentThemeIndex = 0;

    // Load saved theme if exists
    const savedTheme = localStorage.getItem('ajo-theme');
    if (savedTheme && themes.includes(savedTheme)) {
      currentThemeIndex = themes.indexOf(savedTheme);
      setTheme(savedTheme);
    }

    document.getElementById('theme-switcher').addEventListener('click', () => {
      currentThemeIndex = (currentThemeIndex + 1) % themes.length;
      const nextTheme = themes[currentThemeIndex];
      setTheme(nextTheme);
    });

    function setTheme(themeName) {
      document.documentElement.setAttribute('data-theme', themeName);
      localStorage.setItem('ajo-theme', themeName);
      
      // Update theme name in UI
      const themeLabel = document.getElementById('current-theme-name');
      themeLabel.textContent = themeName.toUpperCase();
      
      // Re-initialize icons if needed
      lucide.createIcons();
    }

    // Copy to Clipboard Utility
    function copyCommand(text, buttonId) {
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById(buttonId);
        const originalHTML = btn.innerHTML;
        
        // Update button to show success
        btn.innerHTML = '<i data-lucide="check" class="w-4 h-4 text-secondary"></i>';
        lucide.createIcons();
        
        setTimeout(() => {
          btn.innerHTML = originalHTML;
          lucide.createIcons();
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy text: ', err);
      });
    }

    // Installation Section Tab Switcher
    const codeSnippets = {
      uv: `# Recommended Install as a tool with uv\nuv tool install ajo-cli\n\n# Run ajo\najo`,
      pipx: `# Recommended — isolated environment\npipx install ajo-cli\n\n# With pip (global)\npip install ajo-cli\n\n# Run ajo\najo`,
      aur: `# Install using yay\nyay -S ajo-cli\n\n# Or using paru\nparu -S ajo-cli`,
      source: `# Clone the repository\ngit clone https://github.com/zaidejjo/ajo-cli.git\ncd ajo-cli\n\n# Sync dependencies and install with uv\nuv sync && uv tool install . --force\n\n# Run ajo\najo`
    };

    let activeTab = 'uv';

    function switchTab(tabName) {
      // Update active tab state
      const tabs = ['uv', 'pipx', 'aur', 'source'];
      tabs.forEach(t => {
        const tabBtn = document.getElementById(`tab-${t}`);
        if (t === tabName) {
          tabBtn.classList.remove('text-muted', 'border-b-transparent');
          tabBtn.classList.add('text-primary', 'border-b-primary', 'bg-panel/30');
        } else {
          tabBtn.classList.remove('text-primary', 'border-b-primary', 'bg-panel/30');
          tabBtn.classList.add('text-muted', 'border-b-transparent');
        }
      });

      // Update code block content
      const codeBlock = document.getElementById('code-block');
      codeBlock.innerHTML = `<code>${codeSnippets[tabName]}</code>`;
      activeTab = tabName;
    }

    function copyTabCode() {
      const codeText = codeSnippets[activeTab];
      copyCommand(codeText, 'copy-tab-btn');
    }

    // Interactive Terminal Simulator Animation
    const terminalScreen = document.getElementById('terminal-screen');
    let terminalTimeoutIds = [];

    const asciiLogo = ` █████╗      ██╗ ██████╗ 
██╔══██╗     ██║██╔═══██╗
███████║     ██║██║   ██║
██╔══██║██   ██║██║   ██║
██║  ██║╚█████╔╝╚██████╔╝
╚═╝  ╚═╝ ╚════╝  ╚═════╝ `;

    function sleep(ms) {
      return new Promise(resolve => {
        const id = setTimeout(resolve, ms);
        terminalTimeoutIds.push(id);
      });
    }

    function clearTerminal() {
      terminalScreen.innerHTML = '';
    }

    function printLine(text, className = '') {
      const div = document.createElement('div');
      if (className) div.className = className;
      div.innerHTML = text;
      terminalScreen.appendChild(div);
      terminalScreen.scrollTop = terminalScreen.scrollHeight;
    }

    async function typeText(text, className = '') {
      const div = document.createElement('div');
      if (className) div.className = className;
      div.classList.add('cursor-blink');
      terminalScreen.appendChild(div);
      
      for (let i = 0; i < text.length; i++) {
        div.textContent += text[i];
        terminalScreen.scrollTop = terminalScreen.scrollHeight;
        await sleep(60 + Math.random() * 40);
      }
      
      div.classList.remove('cursor-blink');
    }

    async function runTerminalAnimation() {
      clearTerminal();
      
      // Step 1: Type command
      printLine('<span class="text-muted">ajo@terminal:~$</span> ', 'inline');
      await sleep(500);
      await typeText('ajo', 'inline-block');
      await sleep(300);
      printLine(''); // Newline
      
      // Step 2: Render Logo
      await sleep(200);
      printLine(`<pre class="text-primary text-glow-primary font-bold leading-tight">${asciiLogo}</pre>`);
      await sleep(400);
      printLine('<span class="text-primary font-bold">AJO v3.3.0</span> - Professional Django Scaffolder');
      printLine('Initializing interactive scaffold session...\n', 'text-muted');
      await sleep(800);

      // Step 3: Prompt Preset
      printLine('<span class="text-secondary font-bold">?</span> <span class="font-bold">Choose Architecture Preset:</span>');
      const presetDiv = document.createElement('div');
      presetDiv.className = 'space-y-1 pl-4';
      presetDiv.innerHTML = `
        <div id="p-mono" class="text-primary font-bold">&gt; Standard Monolith (Django + Bootstrap 5 + HTMX)</div>
        <div id="p-rest" class="text-muted">&nbsp;&nbsp;REST API Ready (DRF + JWT + CORS + Swagger)</div>
        <div id="p-ninja" class="text-muted">&nbsp;&nbsp;Ninja API (django-ninja + Pydantic + Swagger)</div>
        <div id="p-graphql" class="text-muted">&nbsp;&nbsp;GraphQL API (Graphene + Relay + GraphiQL)</div>
        <div id="p-docker" class="text-muted">&nbsp;&nbsp;Docker (Multi-stage Dockerfile + Compose)</div>
      `;
      terminalScreen.appendChild(presetDiv);
      terminalScreen.scrollTop = terminalScreen.scrollHeight;
      
      // Animate selection down to REST API
      await sleep(1000);
      document.getElementById('p-mono').className = 'text-muted';
      document.getElementById('p-mono').innerHTML = '&nbsp;&nbsp;Standard Monolith (Django + Bootstrap 5 + HTMX)';
