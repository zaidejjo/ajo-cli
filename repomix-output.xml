          }
        }
      }
    }
  </script>
  
  <!-- Custom Styles for Cyberpunk TUI Aesthetic -->
  <style>
    :root {
      /* Cyberpunk Theme (Default) */
      --color-bg: #0a0b10;
      --color-panel: #12131a;
      --color-accent-primary: #00f2fe; /* Neon Cyan */
      --color-accent-primary-glow: rgba(0, 242, 254, 0.35);
      --color-accent-secondary: #00ffcc; /* Matrix Green */
      --color-accent-secondary-glow: rgba(0, 255, 204, 0.35);
      --color-accent-tertiary: #f355da; /* Cyber Pink */
      --color-accent-tertiary-glow: rgba(243, 85, 218, 0.35);
      --color-text-muted: #8f9bb3;
      --color-text-bright: #ffffff;
    }

    [data-theme="dracula"] {
      /* Dracula Theme */
      --color-bg: #0b0914;
      --color-panel: #181425;
      --color-accent-primary: #bd93f9; /* Dracula Purple */
      --color-accent-primary-glow: rgba(189, 147, 249, 0.35);
      --color-accent-secondary: #50fa7b; /* Dracula Green */
      --color-accent-secondary-glow: rgba(80, 250, 123, 0.35);
      --color-accent-tertiary: #ff79c6; /* Dracula Pink */
      --color-accent-tertiary-glow: rgba(255, 121, 198, 0.35);
      --color-text-muted: #a4b1cd;
      --color-text-bright: #f8f8f2;
    }

    [data-theme="monochromatic"] {
      /* Monochromatic Theme */
      --color-bg: #0f172a; /* Slate 900 */
      --color-panel: #1e293b; /* Slate 800 */
      --color-accent-primary: #cbd5e1; /* Slate 300 */
      --color-accent-primary-glow: rgba(203, 213, 225, 0.25);
      --color-accent-secondary: #38bdf8; /* Sky 400 */
      --color-accent-secondary-glow: rgba(56, 189, 248, 0.35);
      --color-accent-tertiary: #94a3b8; /* Slate 400 */
      --color-accent-tertiary-glow: rgba(148, 163, 184, 0.25);
      --color-text-muted: #64748b; /* Slate 500 */
      --color-text-bright: #f8fafc; /* Slate 50 */
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    ::-webkit-scrollbar-track {
      background: var(--color-bg);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--color-panel);
      border: 1px solid var(--color-accent-primary);
      border-radius: 2px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--color-accent-primary);
    }

    /* CRT Scanline Effect */
    .crt-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.04), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.04));
      background-size: 100% 4px, 6px 100%;
      z-index: 9999;
      pointer-events: none;
      opacity: 0.15;
    }

    /* Grid Overlay */
    .grid-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
      background-size: 40px 40px;
      z-index: 1;
      pointer-events: none;
    }

    /* Subtle scanline animation */
    @keyframes scanline {
      0% { transform: translateY(-100%); }
      100% { transform: translateY(100%); }
    }

    .scanline-bar {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 10px;
      background: linear-gradient(to bottom, transparent, var(--color-accent-primary), transparent);
      opacity: 0.03;
      z-index: 9998;
      pointer-events: none;
      animation: scanline 15s linear infinite;
    }

    /* Glow Effects */
    .text-glow-primary {
      text-shadow: 0 0 8px var(--color-accent-primary);
    }
    .text-glow-secondary {
      text-shadow: 0 0 8px var(--color-accent-secondary);
    }
    .text-glow-tertiary {
      text-shadow: 0 0 8px var(--color-accent-tertiary);
    }

    /* Blinking Cursor */
    .cursor-blink::after {
      content: '█';
      display: inline-block;
      margin-left: 2px;
      animation: blink 1s step-end infinite;
    }
    @keyframes blink {
      from, to { opacity: 1; }
      50% { opacity: 0; }
    }

    /* Pulsing Status Dot */
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(1.25); }
    }
    .pulse-dot {
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    /* Cyberpunk Border Corners */
    .cyber-corners {
      position: relative;
    }
    .cyber-corners::before, .cyber-corners::after {
      content: '';
      position: absolute;
      width: 10px;
      height: 10px;
      border-color: var(--color-accent-primary);
      border-style: solid;
      pointer-events: none;
    }
    .cyber-corners::before {
      top: -1px;
      left: -1px;
      border-width: 2px 0 0 2px;
    }
    .cyber-corners::after {
      bottom: -1px;
      right: -1px;
      border-width: 0 2px 2px 0;
    }

    /* Custom Terminal Line Height & Spacing */
    .terminal-output {
      line-height: 1.5;
    }
  </style>
</head>
